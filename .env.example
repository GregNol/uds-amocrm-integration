# Скопируйте в .env и заполните значения. Файл .env в .gitignore — в репозиторий не попадает.

# ---------- App / домен ----------
APP_DOMAIN=

# ---------- amoCRM ----------
AMOCRM_SUBDOMAIN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
# Долгосрочный токен (если задан — OAuth не нужен)
AMOCRM_LONG_LIVED_TOKEN=

# Воронка и статусы (узнать через scripts/dump_amocrm_meta.py после авторизации)
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_NEW_ID=
AMOCRM_STATUS_WON_ID=

# ID кастомных полей сделки
AMOCRM_CF_SOURCE_ID=
AMOCRM_CF_AMOUNT_ID=
AMOCRM_CF_ORDER_ID=

# ---------- UDS ----------
UDS_COMPANY_ID=
UDS_API_KEY=
UDS_WEBHOOK_SECRET=
# Проверка подписи вебхуков (X-Signature). Ключ — из настроек вебхука в UDS.
UDS_WEBHOOK_SIGNING_KEY=
UDS_VERIFY_SIGNATURE=false

# ---------- Postgres ----------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ---------- App ----------
LOG_LEVEL=INFO
